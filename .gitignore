```gitignore
# Dependencies
node_modules/

# Build outputs
build/
dist/
coverage/

# Logs
*.log

# OS files
.DS_Store

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging.local
.env.*.local

# Ignore all env files
.env*

# But keep example env files
!.env.example
!.env*.example
```
